---
interface Props {
  src: string;
  height?: string;
  title?: string;
}

const { src, height = '400px', title = 'Live preview' } = Astro.props;
---

<div class="form-preview">
  <div class="form-preview-header">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
    <span>Live Preview</span>
  </div>
  <iframe src={src} style={`height: ${height};`} title={title} loading="lazy"></iframe>
</div>

<style>
  .form-preview {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    overflow: hidden;
    margin: 1rem 0 1.5rem;
  }

  .form-preview-header {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    background: var(--sl-color-gray-6);
    border-bottom: 1px solid var(--sl-color-gray-5);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--sl-color-gray-2);
  }

  .form-preview iframe {
    width: 100%;
    border: none;
    display: block;
    background: var(--sl-color-bg);
  }
</style>
